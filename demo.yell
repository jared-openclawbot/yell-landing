# demo.yell — Yell configuration for the demo landing page
# This file defines the structure of the GitHub Pages demo page.
# It demonstrates Yell's component system, design tokens, and declarative UI.

tokens:
  colors:
    brand: '#ff8a3d'
    brand-dim: 'rgba(255, 138, 61, 0.12)'
    bg: '#0a0a0f'
    surface: '#12121a'
    surface-2: '#18182a'
    border: '#1e1e2e'
    text: '#e4e4ef'
    muted: '#6b6b8a'
    success: '#34d399'
    info: '#60a5fa'
    warning: '#fbbf24'
    error: '#f87171'
  spacing:
    xs: '4px'
    sm: '8px'
    md: '16px'
    lg: '24px'
    xl: '48px'
    section: '80px'
  font:
    sans: "'Inter', -apple-system, sans-serif"
    mono: "'JetBrains Mono', monospace"

app:
  shell:
    type: Container
    layout: stack
    gap: 0

  children:

    # ─── Navbar ──────────────────────────────────────────────────────
    - type: Container
      layout: row
      gap: 0
      style: 'position:fixed;top:0;left:0;right:0;z-index:100;padding:14px 48px;background:rgba(10,10,15,0.88);backdrop-filter:blur(16px);border-bottom:1px solid $tokens.colors.border;'
      children:
        - type: Logo
          props:
            label: 'Yell'
            href: '#'
            icon: 'Y'
        - type: Container
          layout: row
          gap: 28
          style: 'margin-left:auto;'
          children:
            - type: NavLink
              props:
                label: 'Live Editor'
                href: '#live-editor'
            - type: NavLink
              props:
                label: 'Features'
                href: '#features'
            - type: NavLink
              props:
                label: 'Components'
                href: '#components'
            - type: NavLink
              props:
                label: 'Docs'
                href: 'docs/getting-started/introduction.html'
            - type: NavLink
              props:
                label: 'GitHub'
                href: 'https://github.com/jared-openclawbot/yell-landing'
                target: '_blank'
            - type: Button
              props:
                label: 'Try it →'
                variant: cta
                href: '#live-editor'

    # ─── Hero ────────────────────────────────────────────────────────
    - type: Container
      layout: stack
      gap: 40
      style: 'padding:140px 48px 80px;max-width:860px;margin:0 auto;text-align:center;'
      children:
        - type: Badge
          props:
            label: 'v0.1.0 — AI-native UI framework'
            variant: brand
            showDot: true
        - type: Heading
          props:
            content: 'UI defined in <span class="gradient">YAML</span>.<br>Rendered everywhere.'
            level: h1
            style: 'font-size:clamp(36px,6vw,64px);font-weight:800;line-height:1.1;letter-spacing:-0.03em;'
        - type: Text
          props:
            content: 'Yell replaces JSX with structured YAML. Every component is typed, versioned, and validated. AI agents and platform teams share one source of truth.'
            style: 'font-size:17px;color:$tokens.colors.muted;max-width:560px;margin:0 auto;line-height:1.7;'
        - type: Container
          layout: row
          gap: 14
          justify: center
          style: 'flex-wrap:wrap;'
          children:
            - type: Button
              props:
                label: 'Try the live editor →'
                variant: primary
                href: '#live-editor'
            - type: Button
              props:
                label: 'View on GitHub'
                variant: secondary
                href: 'https://github.com/jared-openclawbot/yell-landing'

    # ─── Live Editor ─────────────────────────────────────────────────
    - type: Container
      layout: stack
      gap: 6
      style: 'padding:0 48px 80px;max-width:1200px;margin:0 auto;'
      children:
        - type: Badge
          props:
            label: 'Live Editor'
            variant: brand
        - type: Heading
          props:
            content: 'YAML in, HTML out'
            level: h2
            style: 'font-size:28px;font-weight:800;letter-spacing:-0.02em;'
        - type: Text
          props:
            content: 'Edit the YAML on the left — see the rendered output on the right, instantly.'
            style: 'color:$tokens.colors.muted;font-size:14px;margin-bottom:28px;'
        - type: EditorShell
          props:
            defaultYaml: |
              app:
                children:
                  - type: Container
                    layout: stack
                    gap: 16
                    children:
                      - type: Text
                        content: Welcome to Yell
                        variant: h1
                      - type: Button
                        label: Get started
                        variant: primary
                      - type: Badge
                        label: v0.1.0
                        variant: success

    # ─── Features ─────────────────────────────────────────────────────
    - type: Container
      layout: stack
      gap: 12
      style: 'padding:$tokens.spacing.section 48px;max-width:1100px;margin:0 auto;'
      children:
        - type: Badge
          props:
            label: 'Why Yell'
            variant: brand
        - type: Heading
          props:
            content: 'Built for AI-native development'
            level: h2
            style: 'font-size:32px;font-weight:800;letter-spacing:-0.02em;'
        - type: Text
          props:
            content: 'Yell was designed from the ground up to be generated, validated, and governed by AI agents.'
            style: 'color:$tokens.colors.muted;font-size:16px;margin-bottom:48px;max-width:520px;'
        - type: FeaturesGrid
          columns: 3
          gap: 20
          items:
            - icon: '📐'
              title: 'Structured over syntax'
              body: 'YAML has strict indentation and structure. LLMs produce cleaner, more consistent output than with ad-hoc JSX.'
            - icon: '🔒'
              title: 'Schema-validated components'
              body: 'Every component has a typed schema. Invalid props are caught at parse time, not runtime.'
            - icon: '🤖'
              title: 'AI guardrails built-in'
              body: 'The linter blocks inline functions, ternary expressions, and function calls — keeping AI-generated YAML safe and predictable.'
            - icon: '🎨'
              title: 'Design tokens as contracts'
              body: 'Tokens are defined once and referenced everywhere. AI uses them to generate consistent UIs without hardcoded values.'
            - icon: '⚡'
              title: 'SSR + hydration islands'
              body: 'Render on the server, hydrate on the client. Selective hydration for interactive components only.'
            - icon: '📦'
              title: 'Monorepo packages'
              body: '@yell/core, @yell/schema, @yell/ai-adapter, @yell/linter — each independently usable, all designed to work together.'

    # ─── Component Showcase ───────────────────────────────────────────
    - type: Container
      layout: stack
      gap: 36
      style: 'padding:$tokens.spacing.section 48px;max-width:1100px;margin:0 auto;'
      children:
        - type: Badge
          props:
            label: 'Components'
            variant: brand
        - type: Heading
          props:
            content: "What's available"
            level: h2
            style: 'font-size:32px;font-weight:800;letter-spacing:-0.02em;'
        - type: ComponentGrid
          columns: 4
          gap: 14
          items:
            - name: 'Button'
              preview:
                type: Button
                props:
                  label: 'Click me'
                  variant: primary
            - name: 'Button variants'
              preview:
                type: Container
                layout: stack
                gap: 6
                children:
                  - type: Button
                    props:
                      label: primary
                      variant: primary
                  - type: Button
                    props:
                      label: secondary
                      variant: secondary
                  - type: Button
                    props:
                      label: ghost
                      variant: ghost
            - name: 'Button sizes'
              preview:
                type: Container
                layout: column
                gap: 6
                children:
                  - type: Button
                    props:
                      label: small
                      variant: primary
                      size: sm
                  - type: Button
                    props:
                      label: medium
                      variant: primary
                  - type: Button
                    props:
                      label: large
                      variant: primary
                      size: lg
            - name: 'Badge'
              preview:
                type: Container
                layout: column
                gap: 6
                align: flex-start
                children:
                  - type: Badge
                    props:
                      label: Default
                      variant: default
                  - type: Badge
                    props:
                      label: Success
                      variant: success
                  - type: Badge
                    props:
                      label: Info
                      variant: info
                  - type: Badge
                    props:
                      label: Warning
                      variant: warning
            - name: 'Input'
              preview:
                type: Input
                  props:
                    placeholder: 'Type something…'
            - name: 'Card'
              preview:
                type: Card
                  props:
                    title: Card Title
                    body: Card body content
            - name: 'Modal'
              preview:
                type: Modal
                  props:
                    label: MODAL
                    body: Overlay content
            - name: 'Text'
              preview:
                type: Container
                layout: stack
                gap: 4
                align: flex-start
                children:
                  - type: Text
                    props:
                      content: Heading 1
                      variant: h1
                  - type: Text
                    props:
                      content: Heading 2
                      variant: h2
                  - type: Text
                    props:
                      content: Body text
                      variant: body

    # ─── CTA Section ──────────────────────────────────────────────────
    - type: Container
      layout: column
      gap: 36
      style: 'padding:80px 48px 100px;text-align:center;'
      children:
        - type: Card
          props:
            maxWidth: 680
            style: 'margin:0 auto;background:$tokens.colors.surface;border:1px solid $tokens.colors.border;border-radius:20px;padding:56px 64px;'
          children:
            - type: Heading
              props:
                content: 'Start building with Yell'
                level: h2
                style: 'font-size:32px;font-weight:800;letter-spacing:-0.02em;'
            - type: Text
              props:
                content: 'Define your design system in YAML once. Generate UIs with AI. Validate everything with schemas.'
                style: 'color:$tokens.colors.muted;font-size:16px;margin-bottom:36px;'
            - type: Container
              layout: row
              gap: 14
              justify: center
              style: 'flex-wrap:wrap;'
              children:
                - type: Button
                  props:
                    label: 'Read the docs →'
                    variant: primary
                    href: 'docs/getting-started/introduction.html'
                - type: Button
                  props:
                    label: 'View on GitHub'
                    variant: secondary
                    href: 'https://github.com/jared-openclawbot/yell-landing'

    # ─── Footer ───────────────────────────────────────────────────────
    - type: Container
      layout: row
      justify: space-between
      align: center
      style: 'padding:28px 48px;border-top:1px solid $tokens.colors.border;'
      children:
        - type: Text
          props:
            content: 'Yell v0.1.0'
            style: 'font-size:13px;font-weight:700;color:$tokens.colors.muted;'
        - type: Container
          layout: row
          gap: 22
          children:
            - type: NavLink
              props:
                label: 'Docs'
                href: 'docs/getting-started/introduction.html'
            - type: NavLink
              props:
                label: 'Components'
                href: 'docs/core-concepts/components.html'
            - type: NavLink
              props:
                label: 'AI Generation'
                href: 'docs/guides/ai-generation.html'
            - type: NavLink
              props:
                label: 'GitHub'
                href: 'https://github.com/jared-openclawbot/yell-landing'